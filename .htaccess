# 원페이지 홈 + 블로그만 별도
<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteRule ^robots\.txt$ /robots.php [L]
  RewriteRule ^sitemap\.xml$ /sitemap.php [L]

  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # 구 경로 → 홈 (해시 스크롤은 클라이언트)
  RewriteRule ^(cases|services|guide|contact)/?$ /index.php [L,QSA]

  # 블로그·법무
  RewriteRule ^(blog|admin/blog|privacy|terms)(/.*)?$ /index.php [L,QSA]
</IfModule>
